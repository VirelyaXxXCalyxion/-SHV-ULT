---
import MainNav from "../components/MainNav.astro";

const {
    title,
    summary,
    created,
    updated,
    tags = [],
    authors = [],
    authorshipNote,
    publicationStatus = "ashvault-only",
    mediumUrl,
    canonicalUrl,
    series,
    disclosure,
    backHref = "/sovereign-chamber/authored-works",
    backLabel = "Return to Authored Works",
    laneLabel = "Chamber Text",
} = Astro.props;

const formattedCreated = created
    ? new Date(created).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
      })
    : null;

const formattedUpdated = updated
    ? new Date(updated).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
      })
    : null;

const publicationLabels = {
    "ashvault-only": "Ashvault Origin",
    submitted: "Submitted to Medium",
    published: "Carried to Medium",
};

const publicationLabel =
    publicationLabels[publicationStatus as keyof typeof publicationLabels] ??
    publicationStatus;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title} — The Sovereign Chamber</title>
        {summary && <meta name="description" content={summary} />}
        {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Lora:wght@400;500;600&display=swap"
            rel="stylesheet"
        />
        <link rel="stylesheet" href="/sovereign-chamber.css" />
    </head>
    <body class="sovereign-body">
        <main class="sovereign-shell">
            <MainNav />
            <div class="sovereign-frame">
                <div class="sovereign-topbar">
                    <a class="sovereign-back" href={backHref}>{backLabel}</a>
                    <div class="sovereign-mark">Authored Works Entry</div>
                </div>

                <section class="sovereign-lane-page sovereign-entry-page">
                    <header
                        class="sovereign-lane-page-header sovereign-entry-header"
                    >
                        <div>
                            <div class="sovereign-lane-kicker">{laneLabel}</div>
                            <h1 class="sovereign-lane-title">{title}</h1>
                            {
                                summary && (
                                    <p class="sovereign-lane-intro">
                                        {summary}
                                    </p>
                                )
                            }
                        </div>
                    </header>

                    <div class="sovereign-entry-page-meta">
                        {authors.length > 0 && <span>By: {authors.join(" & ")}</span>}
                        <span>{publicationLabel}</span>
                        {
                            formattedCreated && (
                                <span>Created: {formattedCreated}</span>
                            )
                        }
                        {formattedUpdated && <span>Updated: {formattedUpdated}</span>}
                        {series && <span>Series: {series}</span>}
                        {tags.length > 0 && <span>Tags: {tags.join(" ")}</span>}
                    </div>

                    {
                        authorshipNote && (
                            <p class="sovereign-provenance">{authorshipNote}</p>
                        )
                    }

                    {
                        mediumUrl && (
                            <div class="sovereign-link-row">
                                <a
                                    class="sovereign-link"
                                    href={mediumUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Read on Medium
                                </a>
                            </div>
                        )
                    }

                    {
                        disclosure && (
                            <aside class="sovereign-disclosure">
                                <span>Authorship and provenance</span>
                                <p>{disclosure}</p>
                            </aside>
                        )
                    }

                    <article class="sovereign-entry-prose">
                        <slot />
                    </article>
                </section>
            </div>
        </main>
    </body>
</html>
