---
import { getCollection } from "astro:content";
import RelicCard from "../../../components/RelicCard.astro";

const relics = await getCollection("music-relics");
const sorted = relics.sort((a,b) => (a.data.created < b.data.created ? 1 : -1));
---

<h1>Music Relics</h1>
<p>A catalogue of tracks that hold function: rage → clarity, ache → movement, devotion → return.</p>

<div class="grid">
  {sorted.map(r => (
    <RelicCard
      title={r.data.title}
      artist={r.data.artist}
      kind={r.data.kind}
      mood={r.data.mood}
      themes={r.data.themes}
      href={`/relics/music/${r.slug}/`}
    />
  ))}
</div>

<style>
  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:14px;margin-top:18px;}
  p{opacity:.85;max-width:68ch;}
</style>
