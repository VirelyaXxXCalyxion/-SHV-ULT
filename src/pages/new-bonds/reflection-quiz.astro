        mirror: {
          name: "Mirror",
          title: "The Truth Reflector",
          description:
            "You connect through honest reflection and mutual seeing. You seek truth in connection. You want to be seen fully and you offer that same clarity back. Vulnerability isn't weakness to you — it's the only way real connection happens.",
