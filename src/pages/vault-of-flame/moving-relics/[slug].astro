---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import MainNav from "../../../components/MainNav.astro";

export async function getStaticPaths() {
  const relics = (await getCollection("video-relics")).filter(
    (entry) => entry.data.visibility === "public",
  );

  return relics.map((relic) => ({
    params: { slug: relic.id },
    props: { relic },
  }));
}

const { relic } = Astro.props as { relic: CollectionEntry<"video-relics"> };
const { Content } = await render(relic);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{relic.data.title} - Moving Relics - Ashvault</title>
    <meta name="description" content={relic.data.summary ?? relic.data.invocation} />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Montserrat:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <MainNav />
    <main>
      <a class="back" href="/vault-of-flame/moving-relics">Moving Relics</a>
      <article>
        <p class="eyebrow">
          {new Date(relic.data.created).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
          <span aria-hidden="true"> / </span>{relic.data.medium}
        </p>
        <h1>{relic.data.title}</h1>
        <p class="invocation">{relic.data.invocation}</p>
        {relic.data.image && <img src={relic.data.image} alt="" />}
        <div class="body"><Content /></div>
        <a class="watch" href={relic.data.destination} target="_blank" rel="noopener noreferrer">
          Open the moving relic
        </a>
      </article>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) { margin: 0; min-height: 100vh; background: #090806; color: #e8ddc8; font-family: "Montserrat", sans-serif; }
  main { width: min(760px, calc(100% - 2rem)); margin: 0 auto; padding: 7rem 0 4rem; }
  .back, .watch { color: #d89e44; font-family: "Cinzel", serif; text-decoration: none; }
  .back:hover, .back:focus-visible, .watch:hover, .watch:focus-visible { color: #f7d995; text-decoration: underline; text-underline-offset: .25em; }
  article { padding-top: 3rem; }
  .eyebrow { margin: 0 0 1rem; color: #d89e44; font-family: "Cinzel", serif; font-size: .73rem; letter-spacing: .14em; text-transform: uppercase; }
  h1 { margin: 0; color: #f7d995; font-family: "Cinzel", serif; font-size: clamp(2.3rem, 6vw, 4.2rem); font-weight: 600; letter-spacing: 0; }
  .invocation { margin: 1.25rem 0 2rem; color: #c9bda7; font-size: 1.08rem; line-height: 1.7; }
  img { display: block; width: 100%; border: 1px solid rgba(232, 188, 96, .26); border-radius: 6px; }
  .body { color: #ded2bd; line-height: 1.8; }
  .body :global(a) { color: #f1d59b; }
  .watch { display: inline-block; margin-top: 2rem; padding: .85rem 1rem; border: 1px solid rgba(232, 188, 96, .5); border-radius: 4px; }
  @media (max-width: 640px) { main { width: min(100% - 1.5rem, 760px); padding-top: 5.5rem; } article { padding-top: 2.25rem; } }
</style>
